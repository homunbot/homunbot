# =============================================================================
# Homun — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Most settings are configured via the web UI setup wizard after first launch.
# These env vars control Docker-specific behavior.

# --- Domain & HTTPS ---
# Set to your domain for automatic Let's Encrypt HTTPS.
# Leave empty or "localhost" for local development (self-signed cert).
HOMUN_DOMAIN=localhost

# --- Logging ---
# Options: error, warn, info, debug, trace
RUST_LOG=info

# --- LLM Provider API Keys (optional) ---
# These can also be configured via the web UI setup wizard.
# Uncomment and fill in at least one provider.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# --- Embeddings (optional) ---
# Default: Ollama (free, local). Requires: docker compose --profile with-ollama up -d
# Switch to OpenAI embeddings by uncommenting below:
# HOMUN_EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...  (also needed for OpenAI LLM)

# --- Web Search (optional) ---
# BRAVE_API_KEY=
# TAVILY_API_KEY=
